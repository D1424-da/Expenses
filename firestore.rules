rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 書き込み内容の最低限の妥当性チェック（型・サイズ・上限）。
    // 既存データを壊さないよう、未知キーは許容しつつ主要フィールドだけ検証する。
    function validExpense(d) {
      return d.amount is number && d.amount >= 0 && d.amount < 100000000
        && (!('date' in d) || (d.date is string && d.date.size() <= 10))
        && (!('store' in d) || (d.store is string && d.store.size() <= 100))
        && (!('branch' in d) || (d.branch is string && d.branch.size() <= 100))
        && (!('category' in d) || (d.category is string && d.category.size() <= 30))
        && (!('memo' in d) || (d.memo is string && d.memo.size() <= 500))
        && (!('items' in d) || d.items is list)
        && (!('rawText' in d) || (d.rawText is string && d.rawText.size() <= 20000));
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // 各ユーザーは自分のデータ（users/{uid}/...）にのみアクセス可能。
    match /users/{userId}/expenses/{expenseId} {
      allow read, delete: if isOwner(userId);
      allow create, update: if isOwner(userId) && validExpense(request.resource.data);
    }

    // 設定（予算・買い物リスト）。ドキュメントIDは決め打ち（budget / shoppingList）。
    function validSetting(d) {
      return !('items' in d) || (d.items is list && d.items.size() <= 200);
    }
    // サブスクリプション状態はバックエンド（Admin SDK）のみ書き込み可能。
    // フロントからの write を明示的に禁止して不正なプラン昇格を防ぐ。
    match /users/{userId}/settings/subscription {
      allow read: if isOwner(userId);
      allow write: if false;
    }
    match /users/{userId}/settings/{settingId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && validSetting(request.resource.data);
    }

    // 週間献立（カレンダー表示用）。ドキュメントIDは日付（YYYY-MM-DD）。
    function validMealPlan(d) {
      return d.date is string && d.date.size() <= 10
        && (!('朝食' in d) || (d['朝食'] is string && d['朝食'].size() <= 200))
        && (!('お弁当' in d) || (d['お弁当'] is string && d['お弁当'].size() <= 200))
        && (!('夕食' in d) || (d['夕食'] is string && d['夕食'].size() <= 200))
        && (!('朝食レシピ' in d) || (d['朝食レシピ'] is string && d['朝食レシピ'].size() <= 50000))
        && (!('お弁当レシピ' in d) || (d['お弁当レシピ'] is string && d['お弁当レシピ'].size() <= 50000))
        && (!('夕食レシピ' in d) || (d['夕食レシピ'] is string && d['夕食レシピ'].size() <= 50000))
        && (!('savedAt' in d) || d.savedAt is string);
    }
    match /users/{userId}/mealPlans/{mealId} {
      allow read, delete: if isOwner(userId);
      allow create, update: if isOwner(userId) && validMealPlan(request.resource.data);
    }

    // 保存済みレシピ。
    function validRecipe(d) {
      return d.title is string && d.title.size() <= 200
        && d.markdown is string && d.markdown.size() <= 50000
        && (!('items' in d) || (d.items is list && d.items.size() <= 100));
    }
    match /users/{userId}/savedRecipes/{recipeId} {
      allow read, delete: if isOwner(userId);
      allow create, update: if isOwner(userId) && validRecipe(request.resource.data);
    }

    // ---- 世帯共有 ---------------------------------------------------------------
    // households/{hid} の members 配列に uid が含まれるユーザーのみアクセス可能。
    match /households/{householdId} {
      function isHMember() {
        return request.auth != null && request.auth.uid in resource.data.members;
      }

      // 認証済みユーザーは招待コード確認のために読める（参加フロー用）
      allow read: if request.auth != null;

      // 作成: 自分だけを初期メンバーとして作成できる
      allow create: if request.auth != null
        && request.resource.data.members.hasOnly([request.auth.uid])
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.members.size() <= 10;

      // 更新: 既存メンバー OR 新規参加（自分のUIDのみ追加、最大10人）
      allow update: if request.auth != null && (
        isHMember() ||
        (request.resource.data.members.hasAll(resource.data.members)
          && request.resource.data.members.hasAll([request.auth.uid])
          && !resource.data.members.hasAll([request.auth.uid])
          && request.resource.data.members.size() <= resource.data.members.size() + 1
          && request.resource.data.members.size() <= 10)
      );

      // 削除: 作成者のみ
      allow delete: if isHMember() && resource.data.createdBy == request.auth.uid;

      match /expenses/{expenseId} {
        allow read, delete: if isHMember();
        allow create, update: if isHMember() && validExpense(request.resource.data);
      }
      match /settings/{settingId} {
        allow read: if isHMember();
        allow write: if isHMember() && validSetting(request.resource.data);
      }
      match /mealPlans/{mealId} {
        allow read, delete: if isHMember();
        allow create, update: if isHMember() && validMealPlan(request.resource.data);
      }
      match /savedRecipes/{recipeId} {
        allow read, delete: if isHMember();
        allow create, update: if isHMember() && validRecipe(request.resource.data);
      }
    }
  }
}
